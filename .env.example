# Copy to .env and fill in. .env is gitignored; never commit real values.

# --- Secrets (no prefix; read by the SDKs directly) ---
OPENAI_API_KEY=sk-...
# Only needed for `reachy-vec sync-mongo`:
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/

# --- Common overrides (full list: docs/configuration.md) ---
# REACHY_VEC_LLM_MODEL=gpt-5-mini
# REACHY_VEC_LLM_REASONING_EFFORT=minimal
# REACHY_VEC_STT_BACKEND=local          # local | openai (more accurate, ~1s slower)
# REACHY_VEC_STT_MODEL=base.en          # faster-whisper size for the local backend
# REACHY_VEC_FACE_THRESHOLD=0.45        # lower (e.g. 0.40) if known people show as unknown
# REACHY_VEC_CAMERA_INDEX=0
# REACHY_VEC_WEATHER_LAT=53.4084        # lab location for get_weather (default: Liverpool, UK)
# REACHY_VEC_WEATHER_LON=-2.9916

# --- Voice-clone TTS (optional; default backend is macOS `say`) ---
# Record ~10s of clean speech first, e.g.:
#   sox -d -r 24000 -c 1 data/voice_sample.wav trim 0 10
# First qwen-tts run downloads the model from Hugging Face (~1.5 GB).
# REACHY_VEC_TTS_BACKEND=qwen-tts
# REACHY_VEC_VOICE_SAMPLE=data/voice_sample.wav
# Optional transcript of the sample; skips a one-off Whisper auto-transcription.
# REACHY_VEC_VOICE_SAMPLE_TEXT="exact words spoken in the sample"
